<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SDKSample" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/bg_title_bar</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <!-- Fullscreen settings. -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Transparent status bar theme for HomeActivity -->
    <style name="Theme.SDKSample.TransparentStatusBar" parent="Theme.SDKSample">
        <item name="android:statusBarColor" tools:targetApi="l">@color/bg_primary</item>
        <item name="android:windowDrawsSystemBarBackgrounds" tools:targetApi="l">true</item>
    </style>
</resources>